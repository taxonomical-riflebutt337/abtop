Output demo.mp4

Set Shell "bash"
Set FontSize 24
Set Width 2200
Set Height 1200
Set Padding 10
Set Theme "Catppuccin Mocha"
Set Framerate 60

Hide
Type "./target/debug/abtop --demo"
Enter
Sleep 1s
Show

Sleep 1s
Type "j"
Sleep 0.7s
Type "j"
Sleep 0.7s
Type "j"
Sleep 0.7s
Type "k"
Sleep 0.7s
Type "k"
Sleep 0.7s
Type "k"
Sleep 3s

Hide
Type "q"
